# =============================================================================
# .gitignore
# Se versionan SOLO los archivos de ENTRADA y el CÓDIGO necesario para
# reproducir el taller (index.Rmd, modulo_*.Rmd, R/, img/, assets/,
# socsim/socsim_Colombia.sup, README.md y los datos de entrada en data/).
# Todo lo que se GENERA al ejecutar el código queda excluido.
# Los scripts de preparación de datos (prep/) son de uso interno de los docentes
# (dependen de rutas locales) y NO se versionan.
# =============================================================================

# --- R / RStudio ---
.Rproj.user
.Rhistory
.RData
.Ruserdata
.Rapp.history
*.Rproj

# --- Claude / herramientas de IA (no versionar ninguna evidencia de uso) ---
.claude/
.claude*
CLAUDE.md
**/.claude/

# --- Sitio renderizado y artefactos de knitr/rmarkdown (salida) ---
*_files/
*_cache/

# --- Materiales de referencia (PDFs/Word grandes; no forman parte del sitio) ---
_ref/
sim_results_socsim_Colombia.sup*
prep

# --- Datos crudos del WPP (demasiado grandes; se descargan aparte) ---
data/wpp2024_raw/
*.csv.gz

# --- Carpeta heredada del flujo antiguo con .zip (ya no se usa; los datos del
#     WPP se versionan sin comprimir en data/wpp_latam_1950_2023/) ---
data/wpp_latam/

# --- Salidas intermedias del modelo de parentesco (Módulos 2, 3 y 4) ---
# Se regeneran ejecutando los laboratorios o prep/03_build_kinship_colombia.R.
data/colombia/col_kin_1985_2018.parquet
data/kin_*.rds
data/kin_*.parquet

# --- SOCSIM (Módulos 5-6): la simulación corre dentro de socsim/. Se versiona
#     SOLO el archivo de configuración; todo lo generado (presim.*, rates/,
#     sim_results_*) queda excluido. ---
socsim/*
!socsim/socsim_Colombia.sup
data/socsim_*.rds

# Red de seguridad: artefactos de SOCSIM que pudieran quedar en otra carpeta
*.opop
*.omar
*.opox
*.otx
*.pyr
*.pop
*.omor
*.log

# --- Diapositivas (beamer): versionar SOLO el PDF compilado; ignorar la fuente
#     (.tex, refs.bib), las figuras (figures/, figures_src/) y todos los
#     archivos intermedios de LaTeX ---
diapositivas/*
!diapositivas/modulo_1.pdf

# --- Sistema ---
.DS_Store
Thumbs.db
desktop.ini
